<Page
    x:Class="Idasen.SystemTray.Win11.Views.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Idasen.SystemTray.Win11.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Dashboard"
    d:DataContext="{d:DesignInstance local:HomePage,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="600"
    d:DesignWidth="800"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">

    <!-- Main Content Grid with left margin removed to align with standard page padding -->
    <Grid Margin="0,12,0,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Column: Status & Connection -->
        <StackPanel Grid.Column="0" Margin="0,0,12,0">
            <ui:Card Margin="0,0,0,16" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <ui:SymbolIcon x:Name="ConnectionStatusIcon" Symbol="{x:Static ui:SymbolRegular.Bluetooth24}" FontSize="36" Margin="0,0,16,0" VerticalAlignment="Center" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="ConnectionStatusText" Text="Status" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock x:Name="DeviceDetailsText" Text="-" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                    
                    <ui:Button x:Name="ConnectButton" Click="ConnectButton_OnClick" Appearance="Primary" HorizontalAlignment="Stretch" Padding="12,10" Content="Connect">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="{x:Static ui:SymbolRegular.Bluetooth24}" />
                        </ui:Button.Icon>
                    </ui:Button>
                </StackPanel>
            </ui:Card>

            <!-- Information/Tip Card -->
            <ui:Card Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:SymbolIcon Symbol="{x:Static ui:SymbolRegular.Info24}" FontSize="20" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,10,0" />
                        <TextBlock Text="Quick Tip" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="Set up custom positions and hotkeys in the Settings tab to control your desk seamlessly from anywhere." TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" LineHeight="20" />
                </StackPanel>
            </ui:Card>
        </StackPanel>

        <!-- Right Column: Height & Control -->
        <StackPanel Grid.Column="1" Margin="12,0,0,0">
            <ui:Card Padding="20">
                <StackPanel>
                    <TextBlock Text="Desk Control" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" />
                    
                    <!-- Circular Height Display -->
                    <Grid Width="160" Height="160" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <ui:ProgressRing x:Name="HeightProgressRing" 
                                          IsIndeterminate="False"
                                          Progress="0"
                                          Width="160" 
                                          Height="160" />
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="CurrentHeightText" Text="--" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Text="cm" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <!-- Presets / Quick Actions -->
                    <TextBlock Text="Height Presets" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <ui:Button x:Name="SitButton" Grid.Column="0" Click="SitButton_OnClick" Margin="0,0,4,0" Padding="12,14" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="{x:Static ui:SymbolRegular.ArrowCircleDown24}" Margin="0,0,8,0" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="SitButtonText" Text="Sit" FontWeight="SemiBold" />
                                    <TextBlock x:Name="SitHeightText" Text="-- cm" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </ui:Button>

                        <ui:Button x:Name="StandButton" Grid.Column="1" Click="StandButton_OnClick" Margin="4,0,0,0" Padding="12,14" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="{x:Static ui:SymbolRegular.ArrowCircleUp24}" Margin="0,0,8,0" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="StandButtonText" Text="Stand" FontWeight="SemiBold" />
                                    <TextBlock x:Name="StandHeightText" Text="-- cm" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </ui:Button>
                    </Grid>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ui:Button x:Name="Custom1Button" Grid.Column="0" Click="Custom1Button_OnClick" Margin="0,0,4,0" Padding="12,14" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="{x:Static ui:SymbolRegular.ArrowCircleLeft24}" Margin="0,0,8,0" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="Custom1ButtonText" Text="Custom 1" FontWeight="SemiBold" />
                                    <TextBlock x:Name="Custom1HeightText" Text="-- cm" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </ui:Button>

                        <ui:Button x:Name="Custom2Button" Grid.Column="1" Click="Custom2Button_OnClick" Margin="4,0,0,0" Padding="12,14" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="{x:Static ui:SymbolRegular.ArrowCircleRight24}" Margin="0,0,8,0" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="Custom2ButtonText" Text="Custom 2" FontWeight="SemiBold" />
                                    <TextBlock x:Name="Custom2HeightText" Text="-- cm" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </ui:Button>
                    </Grid>

                    <!-- Stop Button -->
                    <ui:Button x:Name="StopButton" Click="StopButton_OnClick" Appearance="Danger" Content="STOP" FontWeight="Bold" FontSize="14" HorizontalAlignment="Stretch" Padding="12,12">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="{x:Static ui:SymbolRegular.Stop24}" />
                        </ui:Button.Icon>
                    </ui:Button>

                </StackPanel>
            </ui:Card>
        </StackPanel>

    </Grid>

</Page>
